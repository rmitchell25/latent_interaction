TITLE:
  LMS Test - Latent by Categorical Interactions

DATA:
  FILE IS mplus_test_data.txt;
  TYPE IS IND;
  NOBS IS 10000;

VARIABLE:
  NAMES ARE G X1-X12 Y1-Y12 G1;
  USEVARIABLES ARE G1 X1-X12 Y1-Y12;

MODEL:
  ! X factor: standardized (Var=1), free loadings
  X BY X1* X2-X12;
  X@1;

  ! Y factor: raw loadings fixed to 1, Var free
  Y BY Y1-Y12;

  ! Free indicator intercepts - except Y1
  [X1-X12];
  [Y1@0];
  [Y2-Y12];
  
  [Y];
 

  ! Latent interactions
  XG | X XWITH G1;

  ! Structural model
  Y ON X G1 XG;

ANALYSIS:
  TYPE = RANDOM;
  ALGORITHM = INTEGRATION;
  MITERATIONS = 10000;
  INTEGRATION = MONTECARLO(1000);

OUTPUT:
  SAMPSTAT TECH1 TECH8;
