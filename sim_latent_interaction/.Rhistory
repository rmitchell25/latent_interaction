library(rblimp)
library(readr)
library(dplyr)
# DATA SET UP ----
load(file = "/Users/remus/Dropbox/ucla/research/classism_mlm_janet_david_chirsty/classism.rda")
# create time id ----
classism <- classism %>%
group_by(PPT.ID) %>%
mutate(ema_time = row_number()) %>%
ungroup()
max_ema <- classism %>%
group_by(PPT.ID) %>%
summarise(max_ema_time = max(ema_time, na.rm = TRUE))
hist(max_ema$max_ema_time, breaks = 20, main = "Max EMA Time per Participant",
xlab = "Maximum EMA Time")
# cut out last few obs w/o
classism <- classism %>%
rowwise() %>%
mutate(higher_ses_any = as.integer(
any(c_across(higher_int1_1mo:higher_int28_1mo) == 1, na.rm = TRUE))
) %>% ungroup()
# Create binary variable for resource use ----
classism <- classism %>%
group_by(PPT.ID) %>%
mutate(resource_any_ema = as.integer(any(resources_use_ema >= 1, na.rm = TRUE))) %>%
ungroup()
# Pull specific variables for analysis ----
classism <- as.data.frame(classism)
data <- classism[,c("PPT.ID","ema_time","antic_stigma_ema","stigma_exp_ema",
"resource_any_ema","income_1yr", "higher_ses_any",
"occupation1_1yr_employ", "int_stress_ema", "int_well_ema",
"int_understanding_ema", "int_threat_ema", "int_empathy_ema",
"int_perspective_ema", "int_willingness_ema", "employ_1yr",
"occupation1_1yr", "employ_1mo", "occupation1_1mo_employ",
"employ_base", "occupation1_base_employ", "occupation1_1yr")]
# reverse code int_stress_ema and int_threat_ema ----
data$int_threat_ema_rev <- 8 - data$int_threat_ema
data$int_stress_ema_rev <- 8 - data$int_stress_ema
# cut out clusters with less than 20 observations ----
# Identify cases that will be removed
cut_cases <- data %>%
group_by(PPT.ID) %>%
summarise(max_ema = max(ema_time, na.rm = TRUE)) %>%
filter(max_ema < 20)
# Print which cases were cut
print(cut_cases)
# Now filter the data
data <- data %>%
group_by(PPT.ID) %>%
filter(max(ema_time, na.rm = TRUE) >= 20) %>%
ungroup()
# create single occupation variable ----
(unique(data$PPT.ID[!is.na(data$occupation1_1yr) & !is.na(data$occupation1_1yr_employ)]))
data <- data %>%
mutate(full_employ_1yr = coalesce(occupation1_1yr_employ, employ_1yr))
data <- data %>%
mutate(full_employ_1mo = coalesce(occupation1_1mo_employ, employ_1mo))
data <- data %>%
mutate(full_employ_base = coalesce(occupation1_base_employ, employ_base))
data <- as.data.frame(data)
# Model 1: composite closeness ----
model2 <- rblimp(data = data,
clusterid = "PPT.ID",
timeid = "ema_time",
latent = "PPT.ID = antic_stigma_ema_mean_j stigma_exp_ema_mean_j",
transform = "closeness = int_stress_ema_rev + int_well_ema +
int_understanding_ema + int_threat_ema_rev +
int_empathy_ema + int_perspective_ema +
int_willingness_ema;
under = missing(higher_ses_any == 0,closeness)",
nominal = "resource_any_ema",
model = "
stigma_exp_ema ~ 1@stigma_exp_ema_mean_j;
antic_stigma_ema_mean_j ~ 1 stigma_exp_ema_mean_j;
antic_stigma_ema ~ 1@antic_stigma_ema_mean_j stigma_exp_ema
(stigma_exp_ema.lag - stigma_exp_ema_mean_j);
logit(resource_any_ema) ~  antic_stigma_ema_mean_j;
under ~ antic_stigma_ema_mean_j;
higher_ses_any ~ antic_stigma_ema_mean_j;
income_1yr ~ closeness.mean resource_any_ema;
occupation1_1yr ~ closeness.mean resource_any_ema;
occupation1_1yr ~~ income_1yr",
burn = 45000,
iter = 45000,
seed = 8675309)
# Model 1: composite closeness ----
model1 <- rblimp(data = data,
clusterid = "PPT.ID",
timeid = "ema_time",
latent = "PPT.ID = antic_stigma_ema_mean_j stigma_exp_ema_mean_j",
transform = "closeness = int_stress_ema_rev + int_well_ema +
int_understanding_ema + int_threat_ema_rev +
int_empathy_ema + int_perspective_ema +
int_willingness_ema;
under = missing(higher_ses_any == 0,closeness)",
nominal = "resource_any_ema",
model = "
stigma_exp_ema ~ 1@stigma_exp_ema_mean_j;
antic_stigma_ema_mean_j ~ 1 stigma_exp_ema_mean_j;
antic_stigma_ema ~ 1@antic_stigma_ema_mean_j stigma_exp_ema
(stigma_exp_ema.lag - stigma_exp_ema_mean_j);
logit(resource_any_ema) ~  antic_stigma_ema_mean_j;
under ~ antic_stigma_ema_mean_j;
higher_ses_any ~ antic_stigma_ema_mean_j;
income_1yr ~ closeness.mean resource_any_ema;
full_employ_1yr ~ closeness.mean resource_any_ema;
full_employ_1yr ~~ income_1yr",
burn = 45000,
iter = 45000,
seed = 8675309)
