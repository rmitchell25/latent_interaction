# Function to compute pairwise differences
compute_diffs <- function(data, model1, model2) {
cov1 <- paste0("coverage_", model1)
cov2 <- paste0("coverage_", model2)
mcse1 <- paste0("mcse_coverage_", model1)
mcse2 <- paste0("mcse_coverage_", model2)
data %>%
mutate(
diff = .data[[cov1]] - .data[[cov2]],
diff_se = sqrt(.data[[mcse1]]^2 + .data[[mcse2]]^2),
z_score = diff / diff_se,
p_value = 2 * pnorm(-abs(z_score))
) %>%
select(categories, group_prob, rsq_prod, sample_size, loading, n_items,
param.id, diff, diff_se, z_score, p_value) %>%
mutate(comparison = paste(model1, "vs", model2))
}
# Apply to all pairs
pairwise_comparisons <- map_dfr(pairs, function(pair) {
compute_diffs(coverage_wide, pair<a href="" class="citation-link" target="_blank" style="vertical-align: super; font-size: 0.8em; margin-left: 3px;">[1]</a>, pair<a href="" class="citation-link" target="_blank" style="vertical-align: super; font-size: 0.8em; margin-left: 3px;">[2]</a>)
